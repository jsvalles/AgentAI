# Copy to .env and fill values
PORT=3000

# Jira Cloud
JIRA_BASE=https://redclay.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_TOKEN=your_jira_api_token

# Confluence (Cloud) - Red Clay Consulting - Knowledge Base
CONFLUENCE_BASE=https://redclay.atlassian.net/wiki
CONFLUENCE_SPACE=KMCELSIA
CONFLUENCE_EMAIL=you@example.com
CONFLUENCE_TOKEN=your_confluence_api_token

# Email Notifications (SMTP)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
SUPPORT_EMAIL=support@example.com

# SharePoint OAuth with Azure AD (Recommended)
# How to get these values:
# 1. Go to https://portal.azure.com
# 2. Azure Active Directory > App registrations > New registration
# 3. Grant permissions: Sites.Read.All, Files.Read.All (Application permissions)
# 4. Create Client Secret in "Certificates & secrets"
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here
SHAREPOINT_TENANT=yourcompany
SHAREPOINT_SITE_NAME=root

# SharePoint Basic Auth (Deprecated - only for testing)
# Note: Microsoft deprecated basic auth for SharePoint Online
SHAREPOINT_USERNAME=your-email@company.com
SHAREPOINT_PASSWORD=your-app-password
